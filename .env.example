# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# GEMINI_API_KEY_POOL: Optional comma-separated list of fallback Google Gemini API keys.
# Used for load-balancing and auto cooldown rotation across up to 100,000 users.
GEMINI_API_KEY_POOL="KEY_1,KEY_2,KEY_3"

# OPENAI_API_KEY: Optional primary key for OpenAI (ChatGPT) fallback models.
OPENAI_API_KEY="MY_OPENAI_API_KEY"

# OPENAI_API_KEY_POOL: Optional comma-separated list of fallback OpenAI keys.
OPENAI_API_KEY_POOL="OPENAI_KEY_1,OPENAI_KEY_2"

# DEEPSEEK_API_KEY: Optional primary key for DeepSeek fallback models.
DEEPSEEK_API_KEY="MY_DEEPSEEK_API_KEY"

# DEEPSEEK_API_KEY_POOL: Optional comma-separated list of fallback DeepSeek keys.
DEEPSEEK_API_KEY_POOL="DEEPSEEK_KEY_1,DEEPSEEK_KEY_2"
